{
  "id": "nikto",
  "name": "Nikto",
  "version": "1.1.0",
  "description": "Web server vulnerability scanner powered by the Nikto CLI",
  "long_description": "Runs Nikto with SecuScan-managed parameters for authorized web server assessment. This modernizes the classic \"nikto -h target\" workflow into a signed plugin with safe argument construction, presets, JSON output, and fallback parsing for traditional Nikto text reports.",
  "category": "web",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "\ud83d\udd0e",
  "engine": {
    "type": "cli",
    "binary": "nikto"
  },
  "command_template": [
    "nikto",
    "-h",
    "{target}",
    "-nointeractive",
    "--if:force_ssl:then:-ssl",
    "--if:follow_redirects:then:-followredirects",
    "--if:no_dns_lookup:then:-nolookup",
    "--if:virtual_host:then:-vhost",
    "--if:virtual_host:then:{virtual_host}",
    "--if:user_agent:then:-useragent",
    "--if:user_agent:then:{user_agent}",
    "-Tuning",
    "{tuning:1234}",
    "-timeout",
    "{request_timeout:10}",
    "-maxtime",
    "{max_scan_time:600}",
    "-Format",
    "json",
    "-output",
    "-"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Target URL",
      "type": "string",
      "required": true,
      "default": "http://127.0.0.1",
      "placeholder": "https://app.example.com",
      "validation": {
        "pattern": "^https?://.+",
        "message": "Enter a full HTTP or HTTPS URL."
      },
      "help": "Authorized web application URL to scan."
    },
    {
      "id": "tuning",
      "label": "Nikto Test Tuning",
      "type": "select",
      "required": false,
      "default": "1234",
      "options": [
        {
          "value": "123b",
          "label": "Passive Baseline"
        },
        {
          "value": "1234",
          "label": "Safe Web Checks"
        },
        {
          "value": "1234567b",
          "label": "Standard Audit"
        },
        {
          "value": "1234567890abc",
          "label": "Full Coverage"
        }
      ],
      "help": "Nikto -Tuning code set. Higher coverage sends more active probes."
    },
    {
      "id": "max_scan_time",
      "label": "Max Scan Time (seconds)",
      "type": "integer",
      "required": false,
      "default": 600,
      "validation": {
        "min": 30,
        "max": 7200,
        "message": "Use a max scan time between 30 and 7200 seconds."
      },
      "help": "Maps to Nikto -maxtime and the SecuScan process timeout."
    },
    {
      "id": "request_timeout",
      "label": "Request Timeout (seconds)",
      "type": "integer",
      "required": false,
      "default": 10,
      "validation": {
        "min": 1,
        "max": 300,
        "message": "Use a per-request timeout between 1 and 300 seconds."
      },
      "help": "Maximum wait time for each target request."
    },
    {
      "id": "virtual_host",
      "label": "Virtual Host",
      "type": "string",
      "required": false,
      "default": "",
      "placeholder": "app.example.com",
      "validation": {
        "pattern": "^$|^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\\.[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$",
        "message": "Enter a valid hostname or leave it blank."
      },
      "help": "Optional Host header value for virtual-hosted targets."
    },
    {
      "id": "user_agent",
      "label": "Custom User Agent",
      "type": "string",
      "required": false,
      "default": "",
      "placeholder": "SecuScan-Nikto/1.0",
      "help": "Optional User-Agent string sent by Nikto."
    },
    {
      "id": "safe_mode",
      "label": "Safe Mode",
      "type": "boolean",
      "required": false,
      "default": true,
      "help": "Keep SecuScan guardrails enabled for conservative target validation."
    },
    {
      "id": "force_ssl",
      "label": "Force SSL",
      "type": "boolean",
      "required": false,
      "default": false,
      "help": "Pass Nikto -ssl for hosts that need SSL forced by port or hostname."
    },
    {
      "id": "follow_redirects",
      "label": "Follow Redirects",
      "type": "boolean",
      "required": false,
      "default": true,
      "help": "Follow HTTP redirects during the scan."
    },
    {
      "id": "no_dns_lookup",
      "label": "Skip DNS Lookup",
      "type": "boolean",
      "required": false,
      "default": false,
      "help": "Pass Nikto -nolookup when DNS resolution is unnecessary or already controlled."
    }
  ],
  "presets": {
    "passive": {
      "tuning": "123b",
      "max_scan_time": 300,
      "request_timeout": 10,
      "safe_mode": true,
      "force_ssl": false,
      "follow_redirects": true,
      "no_dns_lookup": false
    },
    "standard": {
      "tuning": "1234",
      "max_scan_time": 600,
      "request_timeout": 10,
      "safe_mode": true,
      "force_ssl": false,
      "follow_redirects": true,
      "no_dns_lookup": false
    },
    "active": {
      "tuning": "1234567890abc",
      "max_scan_time": 1800,
      "request_timeout": 15,
      "safe_mode": false,
      "force_ssl": false,
      "follow_redirects": true,
      "no_dns_lookup": false
    }
  },
  "output": {
    "format": "json",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "Nikto sends active web probes and can trigger security monitoring. Only scan targets where you have explicit authorization.",
    "allowed_targets": [
      "*"
    ],
    "rate_limit": {
      "max_per_hour": 3,
      "max_concurrent": 1
    }
  },
  "learning": {
    "difficulty": "intermediate",
    "estimated_duration": "5-30 minutes",
    "tutorial_url": "https://docs.secuscan.local/plugins/nikto"
  },
  "dependencies": {
    "binaries": [
      "nikto"
    ],
    "python_packages": [],
    "system_packages": [
      "perl"
    ]
  },
  "docker_image": "sullo/nikto",
  "checksum": "3bda0b32d359908b728a699208cf7c650cd05f111df2beb7ee0d86ebb6ff8613"
}
